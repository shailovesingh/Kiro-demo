{
  "name": "kiro-demo",
  "version": "1.0.0",
  "description": "Demo project for Kiro IDE — showcasing Hooks, MCP (GitHub + Jira), Steering, and Specs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit",
    "lint": "tsc --noEmit"
  },
  "keywords": ["kiro", "demo", "mcp", "hooks", "jira", "github"],
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"],
    "collectCoverageFrom": ["src/**/*.ts"],
    "coverageThreshold": {
      "global": {
        "lines": 80
      }
    }
  }
}
